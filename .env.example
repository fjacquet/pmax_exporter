# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the pmax_exporter binary itself loads .env from
# the working directory (or next to config.yaml). Already-set environment variables
# always take precedence over .env values.

# Exporter image tag (GHCR). Pin a release for production instead of :latest.
PMAX_TAG=latest

# Password for the Unisphere monitoring user. config.yaml references it as ${PMAX1_PASSWORD}.
PMAX1_PASSWORD=changeme

# Optional: override host and username via environment instead of editing config.yaml.
# Useful for single-instance deployments where secrets management sets env vars.
# config.yaml is the source of truth; one entry per Unisphere for multi-instance setups.
PMAX1_HOSTNAME=unisphere01.example.com
PMAX1_USERNAME=pmax-monitor
